{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/documents/:action", "destination": "/api/supabase-documents?action=:action" },
    { "source": "/api/materials/:action", "destination": "/api/material-prices?resource=materials&action=:action" },
    { "source": "/api/prices/:action", "destination": "/api/material-prices?resource=prices&action=:action" },
    { "source": "/api/variations/:action", "destination": "/api/variation-orders?action=:action" },
    { "source": "/api/ai/health", "destination": "/api/ai-proxy" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
