# ── Server-side (Vercel serverless + Vite dev proxy — NOT exposed to browser) ──
OPENAI_API_KEY=sk-proj-your-key-here

# ── Client-side AI (VITE_ prefix required — baked in at build time) ───────────
VITE_AI_USE_PROXY=true
VITE_AI_ENDPOINT=/api/ai-proxy
VITE_AI_HEALTH_URL=/api/ai-proxy
VITE_AI_MODEL=gpt-4.1-mini
VITE_AI_TEMPERATURE=0.7
VITE_AI_TIMEOUT_MS=45000
VITE_AI_MAX_RETRIES=3
VITE_AI_DEBUG=false

# ── Supabase cloud storage (saved documents) ──────────────────────────────────
# Create project at https://supabase.com, run supabase/schema.sql, then paste keys:
# Client (baked in at build time — required for browser cloud sync):
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Server (runtime — used by /api/documents/import; no redeploy needed when only these change):
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Direct browser mode (not recommended — key visible in bundle; CORS may block)
# VITE_AI_USE_PROXY=false
# VITE_OPENAI_API_KEY=sk-proj-your-key-here
# VITE_AI_ENDPOINT=https://api.openai.com/v1/chat/completions

# ── Vercel deployment checklist ───────────────────────────────────────────────
# 1. Set OPENAI_API_KEY in Vercel → Project → Settings → Environment Variables
# 2. Set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY (for browser cloud sync)
#    Also set SUPABASE_URL and SUPABASE_ANON_KEY (for /api/documents/import backup uploads)
# 3. Keep VITE_AI_USE_PROXY=true so the API key stays server-side
# 4. Run supabase/schema.sql in your Supabase SQL editor
# 5. Redeploy after changing any VITE_ variables
